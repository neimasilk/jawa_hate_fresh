# Data — kalau besar, jangan push langsung; pakai DVC/git-lfs/HF nanti
data/raw/
data/intermediate/
data/labeled/*.parquet
data/labeled/*.jsonl
data/golden/*.parquet

# LLM API responses + logs (bisa berisi PII / hate content sebelum anonimisasi)
logs/raw/
logs/llm_responses/

# Run transcripts / pipeline logs (PowerShell Start-Transcript, UTF-16 noisy — bukan artefak reproducible)
experiments/**/outputs/*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Model checkpoints
*.pt
*.pth
*.bin
*.safetensors
checkpoints/
runs/
wandb/

# Secrets (CRITICAL — NEVER commit)
.env
.env.*
*.key
api_keys.json
credentials.json
# .env.example DI-COMMIT sebagai template (tidak berisi rahasia)
!.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# JINITA raw downloads (pihak ketiga / copyright) — simpan SUMMARY.md + template.txt saja
paper/jinita_guidelines/*.html
paper/jinita_guidelines/*.pdf

# Audit report (regenerable via audit.py; memuat cuplikan teks mentah/PII pra-scrub)
experiments/audit_external/audit_report.md

# Expert spot-check working files (teks ofensif + kunci jawaban; skrip .py tetap di-commit)
experiments/expert_spotcheck/*.xlsx
experiments/expert_spotcheck/_key.csv
experiments/expert_spotcheck/spotcheck_result.md
